# =============================================================
# neural-pde-stl-strel — Example environment file
# =============================================================
#
# This file is intended to be *sourced* by your shell.
# It is NOT a plain "dotenv" key=value file (it contains shell logic and `export`).
#
# Usage:
#   cp .env.example .env
#   # bash/zsh:
#   source .env
#   # POSIX sh:
#   . ./.env
#
# Notes:
# - Defaults are "CPU-first" + "demo-safe" (predictable, laptop-friendly).
# - Most settings use "${VAR:-default}". To override, set VAR in your shell
#   *before* sourcing this file, e.g.:
#       OMP_NUM_THREADS=8
#       . ./.env
# - Keep secrets out of this file (and out of git).
#
# =============================================================

# Root of the repo.
#
# Default: directory containing this file (bash/zsh); otherwise the current
# working directory. Override by setting NEURAL_PDE_STL_STREL_REPO_ROOT before sourcing.
if [ -z "${NEURAL_PDE_STL_STREL_REPO_ROOT-}" ]; then
  __NEURAL_PDE_STL_STREL_ENV_FILE=""
  if [ -n "${BASH_VERSION-}" ]; then
    __NEURAL_PDE_STL_STREL_ENV_FILE="${BASH_SOURCE[0]}"
  elif [ -n "${ZSH_VERSION-}" ]; then
    __NEURAL_PDE_STL_STREL_ENV_FILE="${(%):-%x}"
  fi

  if [ -n "$__NEURAL_PDE_STL_STREL_ENV_FILE" ]; then
    NEURAL_PDE_STL_STREL_REPO_ROOT="$(cd "$(dirname "$__NEURAL_PDE_STL_STREL_ENV_FILE")" && pwd)"
  else
    NEURAL_PDE_STL_STREL_REPO_ROOT="$(pwd)"
  fi
  unset __NEURAL_PDE_STL_STREL_ENV_FILE
fi
export NEURAL_PDE_STL_STREL_REPO_ROOT

# --- Project paths / imports -----------------------------------------------
# Add local package to import path.
# (Avoid a trailing ':' when PYTHONPATH is empty.)
export PYTHONPATH="${NEURAL_PDE_STL_STREL_REPO_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"

# Put caches inside the repo (keeps home dirs clean for demos/CI/grading).
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/.cache}"
export MPLCONFIGDIR="${MPLCONFIGDIR:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/.mplconfig}"
export PYTHONPYCACHEPREFIX="${PYTHONPYCACHEPREFIX:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/.pycache}"

# Optional: stable timestamps (useful for reproducible figure filenames).
export TZ="${TZ:-UTC}"

# --- Locale / encoding ------------------------------------------------------
# Ensure consistent UTF-8 logs/paths across machines.
#
# Note: forcing a locale that doesn't exist will print warnings when this file
# is sourced. In particular, macOS often *does not* provide C.UTF-8.
#
# If neither LANG nor LC_ALL is set, pick a UTF-8 locale that is actually
# installed (best-effort).
if [ -z "${LANG:-}" ] && [ -z "${LC_ALL:-}" ] && command -v locale >/dev/null 2>&1; then
  __NEURAL_PDE_STL_STREL_LOCALES="$(locale -a 2>/dev/null || true)"
  __NEURAL_PDE_STL_STREL_UTF8_LOCALE="$(printf '%s\n' "$__NEURAL_PDE_STL_STREL_LOCALES" | grep -iE '^c\.(utf-8|utf8)$' | head -n 1)"
  if [ -z "$__NEURAL_PDE_STL_STREL_UTF8_LOCALE" ]; then
    __NEURAL_PDE_STL_STREL_UTF8_LOCALE="$(printf '%s\n' "$__NEURAL_PDE_STL_STREL_LOCALES" | grep -iE '^en_us\.(utf-8|utf8)$' | head -n 1)"
  fi
  if [ -n "$__NEURAL_PDE_STL_STREL_UTF8_LOCALE" ]; then
    export LANG="$__NEURAL_PDE_STL_STREL_UTF8_LOCALE"
    export LC_ALL="$__NEURAL_PDE_STL_STREL_UTF8_LOCALE"
  fi
  unset __NEURAL_PDE_STL_STREL_LOCALES __NEURAL_PDE_STL_STREL_UTF8_LOCALE
fi

export PYTHONUTF8="${PYTHONUTF8:-1}"
export PYTHONIOENCODING="${PYTHONIOENCODING:-UTF-8}"

# --- Reproducibility / determinism knobs -----------------------------------
# Python hash randomization (affects dict/set iteration order, etc.)
export PYTHONHASHSEED="${PYTHONHASHSEED:-0}"

# Tests read this seed; you can also reuse it in CLI overrides for scripts.
export TEST_SEED="${TEST_SEED:-0}"

# CUDA determinism (no-op on CPU). Still call torch.use_deterministic_algorithms(True) in code.
# PyTorch docs accept either :4096:8 or :16:8 (CUDA >= 10.2).
export CUBLAS_WORKSPACE_CONFIG="${CUBLAS_WORKSPACE_CONFIG:-:4096:8}"

# NOTE: TORCH_USE_CUDA_DSA is a *build-time* PyTorch flag (device-side asserts).
# It has no effect for prebuilt wheels; leave 0 unless building PyTorch from source.
export TORCH_USE_CUDA_DSA="${TORCH_USE_CUDA_DSA:-0}"

# --- Thread caps (CPU predictability) --------------------------------------
# Keep CPU demos predictable and avoid "my laptop is melting".
# Override these if you want faster training on a workstation.
export OMP_NUM_THREADS="${OMP_NUM_THREADS:-1}"
export MKL_NUM_THREADS="${MKL_NUM_THREADS:-1}"
export NUMEXPR_NUM_THREADS="${NUMEXPR_NUM_THREADS:-1}"
export OPENBLAS_NUM_THREADS="${OPENBLAS_NUM_THREADS:-1}"
export VECLIB_MAXIMUM_THREADS="${VECLIB_MAXIMUM_THREADS:-1}"
export BLIS_NUM_THREADS="${BLIS_NUM_THREADS:-1}"
export RAYON_NUM_THREADS="${RAYON_NUM_THREADS:-1}"

# Thread-scheduling policy: disable dynamic adjustment for reproducibility
# and avoid busy-spinning (keeps background CPU usage minimal).
export OMP_DYNAMIC="${OMP_DYNAMIC:-FALSE}"
export MKL_DYNAMIC="${MKL_DYNAMIC:-FALSE}"
export OMP_WAIT_POLICY="${OMP_WAIT_POLICY:-PASSIVE}"

# Quiet HuggingFace tokenizers parallelism (prevents deadlocks after fork).
export TOKENIZERS_PARALLELISM="${TOKENIZERS_PARALLELISM:-false}"

# --- Python runtime hygiene -------------------------------------------------
export PYTHONFAULTHANDLER="${PYTHONFAULTHANDLER:-1}"
export PYTHONUNBUFFERED="${PYTHONUNBUFFERED:-1}"
export PYTHONDONTWRITEBYTECODE="${PYTHONDONTWRITEBYTECODE:-1}"

# Warnings:
# - For demos, keeping output clean is useful.
# - For debugging, consider: PYTHONWARNINGS=default
export PYTHONWARNINGS="${PYTHONWARNINGS:-ignore}"

# --- Paths (data / artifacts) ----------------------------------------------
# Keep all artifacts inside the repo by default.
export DATA_ROOT="${DATA_ROOT:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/data}"

# Makefile-compatible output directories (override any of these as needed).
export RESULTS_DIR="${RESULTS_DIR:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/results}"
export ASSETS_DIR="${ASSETS_DIR:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/assets}"
export FIGS_DIR="${FIGS_DIR:-${FIG_DIR:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/figs}}"
export LOGS_DIR="${LOGS_DIR:-${LOG_DIR:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/logs}}"
export RUNS_DIR="${RUNS_DIR:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/runs}"
export TMP_DIR="${TMP_DIR:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/.tmp}"

# Backwards-compatible aliases (some notes used *_DIR singular).
export LOG_DIR="${LOG_DIR:-${LOGS_DIR}}"
export FIG_DIR="${FIG_DIR:-${FIGS_DIR}}"

# Makefile default device (override: DEVICE=cuda make diffusion1d)
export DEVICE="${DEVICE:-cpu}"

# Tip (paper/report): capture system info once per machine/run, e.g.:
#   mkdir -p "$LOGS_DIR" && python scripts/check_env.py | tee "$LOGS_DIR/sysinfo.txt"

# Tip (paper/report): collect simple runtime + dependency snapshots, e.g.:
#   /usr/bin/time -v python scripts/run_experiment.py -c configs/diffusion1d_stl.yaml --set training.epochs=200 \
#     2>&1 | tee "$LOGS_DIR/time_diffusion1d_stl.txt"
#   python -m pip freeze | tee "$LOGS_DIR/pip_freeze.txt"

# --- Optional stacks toggles ------------------------------------------------
# Import behavior for optional physics frameworks (see src/neural_pde_stl_strel/physics/__init__.py):
# - EAGER_IMPORTS=1  : import optional backends at import time (slower startup, clearer errors)
# - STRICT_INIT=1    : raise if any optional backend import fails
export NEURAL_PDE_STL_STREL_EAGER_IMPORTS="${NEURAL_PDE_STL_STREL_EAGER_IMPORTS:-0}"
export NEURAL_PDE_STL_STREL_STRICT_INIT="${NEURAL_PDE_STL_STREL_STRICT_INIT:-0}"

# If you want to skip import-time probing of optional backends (slightly faster):
# export NEURAL_PDE_STL_STREL_NO_PROBE=1

# --- Matplotlib / plotting --------------------------------------------------
# Headless backend (safe on SSH/CI).
export MPLBACKEND="${MPLBACKEND:-Agg}"

# --- PyTorch / device selection --------------------------------------------
# Prefer CPU by default; allow MPS fallback on macOS.
export PYTORCH_ENABLE_MPS_FALLBACK="${PYTORCH_ENABLE_MPS_FALLBACK:-1}"
export TORCH_CPP_LOG_LEVEL="${TORCH_CPP_LOG_LEVEL:-ERROR}"

# Uncomment to force CPU-only even if CUDA is installed:
# export CUDA_VISIBLE_DEVICES=""

# --- Installation helpers ---------------------------------------------------
# NOTE: Setting PIP_EXTRA_INDEX_URL affects *all* subsequent `pip install`s and can
# change dependency resolution. Prefer per-command overrides instead of exporting a
# global index for every later install.
#
# Per-command (recommended), e.g.:
#   PIP_EXTRA_INDEX_URL="https://pypi.nvidia.com" pip install <package>
#
# Uncomment ONE of the following only if you know you need it globally:
#   # CPU-only torch wheels:
#   # export PIP_EXTRA_INDEX_URL="https://download.pytorch.org/whl/cpu"
#   # NVIDIA PyPI index (PhysicsNeMo ecosystem):
#   # export PIP_EXTRA_INDEX_URL="https://pypi.nvidia.com"

# --- MoonLight (STREL) ------------------------------------------------------
# MoonLight currently requires Java 21+ (see MoonLight prerequisites).
# If your system Java is older, point JAVA_HOME to a newer JDK install.
# export JAVA_HOME="/path/to/jdk-21"

# Keep MoonLight memory bounded for demos.
export JDK_JAVA_OPTIONS="${JDK_JAVA_OPTIONS:--Xmx2g -Xms256m}"

# Path to the default MoonLight script used by the "hello" demo and Heat2D STREL audit.
export NEURAL_PDE_STL_STREL_MLS_PATH="${NEURAL_PDE_STL_STREL_MLS_PATH:-${NEURAL_PDE_STL_STREL_REPO_ROOT}/scripts/specs/contain_hotspot.mls}"

# Verbose MoonLight Java output (default: quiet).
# export NEURAL_PDE_STL_STREL_MOONLIGHT_VERBOSE=1

# --- STREL / Heat2D monitor knobs -------------------------------------------
# The STREL "hello" demo and eval scripts (src/neural_pde_stl_strel/monitors/moonlight_strel_hello.py,
# scripts/eval_heat2d_moonlight.py) read the following env vars to configure the
# spatial monitoring pass. All have sensible defaults; override only as needed.

# Path to a pre-computed 2D heat field (NumPy .npy, shape (nx, ny, nt)).
# If unset, the demo falls back to auto-discovery from assets/heat2d_scalar/.
# export NEURAL_PDE_STL_STREL_HEAT2D_FIELD="/path/to/field_xy_t.npy"

# MoonLight interpretation domain: "boolean" (default) or "minmax" (quantitative robustness).
# export NEURAL_PDE_STL_STREL_STREL_DOMAIN=boolean

# If true, prefer the committed asset field over a synthetic grid for the STREL demo.
# export NEURAL_PDE_STL_STREL_STREL_USE_ASSET=1

# STREL formula name (must match a formula exported from the .mls script).
# export NEURAL_PDE_STL_STREL_STREL_FORMULA=contain_hotspot

# Binarization threshold for the "hot" predicate. If unset, derived from the
# field's quantile (see STREL_QUANTILE below).
# export NEURAL_PDE_STL_STREL_STREL_THRESHOLD=0.3

# Quantile used to auto-derive the threshold when STREL_THRESHOLD is not set.
# export NEURAL_PDE_STL_STREL_STREL_QUANTILE=0.995

# Synthetic grid dimensions (only used when running without a pre-computed field).
# export NEURAL_PDE_STL_STREL_STREL_NX=5
# export NEURAL_PDE_STL_STREL_STREL_NY=5
# export NEURAL_PDE_STL_STREL_STREL_NT=20
# export NEURAL_PDE_STL_STREL_STREL_ALPHA=0.25

# Enable per-timestep field plots from the STREL demo.
# export NEURAL_PDE_STL_STREL_STREL_PLOT=1
# export NEURAL_PDE_STL_STREL_STREL_PLOT_DIR=figs

# --- SpaTiaL / spatial-spec -------------------------------------------------
# spatial-spec's automaton/planning utilities use MONA via `mona` on PATH (Linux-first).
# Quick install on Ubuntu/Debian:  sudo apt install mona
# If mona is in a non-standard location, prepend it to PATH:
#   export PATH="/opt/mona/bin:${PATH}"
# Optionally set the command name explicitly (convention; used by some wrappers):
#   export MONA_CMD="${MONA_CMD:-mona}"

# --- Terminal / output ------------------------------------------------------
# Respect the de-facto NO_COLOR standard (https://no-color.org).
# scripts/check_env.py honours this; set it to disable ANSI color output.
# export NO_COLOR=1

# --- Misc -------------------------------------------------------------------
# If you want profiler-friendly runs (more verbose, slower), you can enable:
# export TORCH_SHOW_CPP_STACKTRACES=1
# export CUDA_LAUNCH_BLOCKING=1

# End of file.
